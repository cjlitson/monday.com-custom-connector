            "itemId": {
              "type": "string",
              "title": "Item ID",
              "description": "The monday.com item ID to update."
            },
            "columnId": {
              "type": "string",
              "title": "Status column ID",
              "description": "The monday.com status column ID, such as status."
            },
            "statusLabel": {
              "type": "string",
              "title": "Status label",
              "description": "The exact status label to apply, such as Done or Working on it."
            }
          }
        }
      }
    },
