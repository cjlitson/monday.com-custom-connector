  "definitions": {
    "GetMondayItemDetailsRequest": {
      "type": "object",
      "required": [
        "query",
        "variables"
      ],
      "properties": {
        "query": {
          "type": "string",
          "title": "GraphQL query",
          "description": "Prebuilt monday.com GraphQL query for item details. Leave the default value unchanged.",
          "default": "query GetMondayItemDetails($itemId: [ID!]!) { items(ids: $itemId) { id name board { id name } group { id title } column_values { id text value type } } }",
          "x-ms-visibility": "internal"
        },
        "variables": {
          "type": "object",
          "title": "Inputs",
          "description": "Friendly inputs for the item details query.",
          "required": [
            "itemId"
          ],
          "properties": {
            "itemId": {
              "type": "string",
              "title": "Item ID",
              "description": "The monday.com item ID to retrieve."
            }
          }
        }
      },
      "example": {
        "query": "query GetMondayItemDetails($itemId: [ID!]!) { items(ids: $itemId) { id name board { id name } group { id title } column_values { id text value type } } }",
        "variables": {
          "itemId": "<ITEM_ID>"
        }
      }
    },
    "CreateMondayItemUpdateRequest": {
      "type": "object",
      "required": [
        "query",
        "variables"
