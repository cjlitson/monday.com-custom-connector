            },
            "body": {
              "type": "string",
              "title": "Update body",
              "description": "The update/comment text to add to the item."
            }
          }
        }
      }
    },
    "ChangeMondayStatusRequest": {
      "type": "object",
      "required": [
        "query",
        "variables"
