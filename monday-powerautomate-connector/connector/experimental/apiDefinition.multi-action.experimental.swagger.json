          "default": "mutation ChangeMondayStatus($boardId: ID!, $itemId: ID!, $columnId: String!, $statusLabel: String!) { change_column_value(board_id: $boardId, item_id: $itemId, column_id: $columnId, value: {label: $statusLabel}) { id } }",
          "x-ms-visibility": "internal"
        },
        "variables": {
          "type": "object",
          "title": "Inputs",
          "description": "Friendly inputs for the status change mutation.",
