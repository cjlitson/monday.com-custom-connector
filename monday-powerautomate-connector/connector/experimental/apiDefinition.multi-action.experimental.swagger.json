          "title": "GraphQL mutation",
          "description": "Prebuilt monday.com GraphQL mutation for creating an item update/comment. Leave the default value unchanged.",
          "default": "mutation CreateMondayItemUpdate($itemId: ID!, $body: String!) { create_update(item_id: $itemId, body: $body) { id body created_at } }",
          "x-ms-visibility": "internal"
        },
        "variables": {
          "type": "object",
          "title": "Inputs",
